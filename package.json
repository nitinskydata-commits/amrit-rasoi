{
  "name": "sbmi-platform",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "server"
  ],
  "description": "SBMI Enterprise E-Commerce Platform",
  "scripts": {
    "server": "npm start --workspace=server",
    "server:dev": "npm run dev --workspace=server",
    "client": "npm start --workspace=apps/customer-web",
    "admin": "npm start --workspace=apps/admin-dashboard",
    "start": "concurrently \"npm run server\" \"npm run client\" \"npm run admin\"",
    "install-all": "npm install"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-keywords": "^5.1.0",
    "concurrently": "^8.2.2"
  }
}
